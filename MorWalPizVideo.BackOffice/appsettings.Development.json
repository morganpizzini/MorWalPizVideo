{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FeatureManagement": {
    "EnableHangFire": false,
    "EnableMock": false,
    "EnableSwagger": true,
    "EnableKeyVault": true
  },
  "AzureConfig": {
    "OpenAi": {
      "DeploymentName": "",
      "OpenAiEndpoint": "",
      "OpenAiKey": ""
    }
  },

  "JwtSettings": {
    "Secret": "development-super-secret-key-with-at-least-32-characters",
    "Issuer": "MorWalPizVideo.BackOffice",
    "Audience": "MorWalPizVideo.BackOffice",
    "ExpirationDays": "7"
  },
  "SecuritySettings": {
    "MaxFailedAttemptsPerIp": 10,
    "MaxFailedAttemptsPerUser": 5,
    "IpRateLimitWindowMinutes": 10,
    "UsernameRateLimitWindowMinutes": 5,
    "CleanupThresholdDays": 7,
    "EnableProgressiveDelays": true
  }
}
