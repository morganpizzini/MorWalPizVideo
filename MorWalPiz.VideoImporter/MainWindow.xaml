<Window x:Class="MorWalPiz.VideoImporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorWalPiz.VideoImporter"
        xmlns:converters="clr-namespace:MorWalPiz.VideoImporter.Converters"
        mc:Ignorable="d"
        Title="Video Importer"
        Height="700"
        Width="1100"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <converters:VideoCompletionStatusToColorConverter x:Key="VideoCompletionStatusToColorConverter"/>
    </Window.Resources>
    <DockPanel>
        <!-- Modern Menu Bar -->
        <Menu DockPanel.Dock="Top" Padding="5">
            <MenuItem Header="File">
                <MenuItem Header="Esci" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Settings" Click="SettingsMenuItem_Click"/>
                <MenuItem Header="Pianificazioni Pubblicazione" Click="PublishSchedulesMenuItem_Click"/>
                <MenuItem Header="Gestione Tenant" Click="TenantManagementMenuItem_Click"/>
                <MenuItem Header="Pulisci credenziali YouTube" Click="ClearYouTubeCredentials_Click"/>
            </MenuItem>
            <MenuItem Header="Entità">
                <MenuItem Header="Lingue" Click="LanguagesMenuItem_Click"/>
                <MenuItem Header="Disclaimer" Click="DisclaimerMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="Funzioni">
                <MenuItem Header="Traduci Video (Manuale)" Click="TranslateVideoMenuItem_Click"/>
                <MenuItem Header="Traduci Video YouTube (Auto)" Click="AutoTranslateYouTubeVideoMenuItem_Click"/>
                <MenuItem Header="Analizza Trascrizione Video" Click="AnalyzeTranscriptMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Card with Actions and Tenant Selector -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- File Selection Buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="BrowseFolderButton"
                                Content="📁 Sfoglia Cartelle"
                                Margin="0,0,10,0"
                                Click="BrowseFolderButton_Click"/>
                        <Button x:Name="BrowseFilesButton"
                                Content="📄 Sfoglia File"
                                Click="BrowseFilesButton_Click"/>
                    </StackPanel>

                    <!-- Tenant Selector -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Tenant:" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,10,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox x:Name="TenantComboBox" 
                                  Width="180" 
                                  DisplayMemberPath="Name" 
                                  SelectedValuePath="Id"
                                  SelectionChanged="TenantComboBox_SelectionChanged"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Publish Date Card -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📅 Data pubblicazione:"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker x:Name="PublishDatePicker"
                                Width="200"
                                Margin="0,0,10,0"
                                SelectedDate="{Binding SelectedPublishDate, Mode=TwoWay}"/>
                    <Button x:Name="ApplyDateButton"
                            Content="Applica"
                            Click="ApplyDateButton_Click"/>
                </StackPanel>
            </Border>

            <!-- File List Card -->
            <GroupBox Grid.Row="2" Header="Video" Margin="0,0,0,20">
                <ListView x:Name="FileListView"
                          MouseDoubleClick="FileListView_MouseDoubleClick"
                          BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="40">
                                <GridViewColumn.Header>
                                    <CheckBox x:Name="SelectAllCheckBox"
                                              Click="SelectAllCheckBox_Checked"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ToolTip="Seleziona/Deseleziona tutti"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" 
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <GridViewColumn Header="#" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4"
                                                Padding="8,4"
                                                Background="{Binding Converter={StaticResource VideoCompletionStatusToColorConverter}}">
                                            <TextBlock Text="{Binding OrderIndex}"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <GridViewColumn Width="60">
                                <GridViewColumn.Header>
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                        <TextBlock Text="Arma" 
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,5"/>
                                        <CheckBox x:Name="SelectAllWeaponCheckBox"
                                                  Click="SelectAllWeaponCheckBox_Checked"
                                                  ToolTip="Seleziona/Deseleziona tutti per arma"/>
                                    </StackPanel>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding containsWeapon, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <GridViewColumn Header="Nome Pulito" Width="220">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CleanFileName}"
                                                   FontWeight="Medium"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <GridViewColumn Header="Path" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FilePath}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   ToolTip="{Binding FilePath}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <GridViewColumn Header="Data di Pubblicazione" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <DatePicker SelectedDate="{Binding PublishDate, Mode=TwoWay}"
                                                        Width="180"
                                                        Margin="0,0,0,5"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="🕐 " VerticalAlignment="Center"/>
                                                <TextBox Width="35"
                                                         Text="{Binding PublishTimeHour, Mode=TwoWay}"
                                                         Tag="Hour"
                                                         Margin="0,0,3,0"
                                                         PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                                                <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                <TextBox Width="35"
                                                         Text="{Binding PublishTimeMinute, Mode=TwoWay}"
                                                         Tag="Minute"
                                                         PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <GridViewColumn Header="Azioni" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Dettagli"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="10,4"
                                                Click="FileDetailButton_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <GridViewColumn Header="Riordina" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="↑"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Width="40"
                                                    Padding="5,2"
                                                    Margin="0,0,5,0"
                                                    ToolTip="Sposta su"
                                                    Click="MoveItemUpButton_Click"/>
                                            <Button Content="↓"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Width="40"
                                                    Padding="5,2"
                                                    ToolTip="Sposta giù"
                                                    Click="MoveItemDownButton_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <!-- Action Buttons -->
            <Border Grid.Row="3" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ContextButton"
                            Grid.Column="0"
                            Content="🌍 Aggiungi Traduzioni"
                            Style="{StaticResource SecondaryButton}"
                            IsEnabled="{Binding HasSelectedItems}"
                            Click="ContextButton_Click"/>

                    <Button x:Name="DeleteButton"
                            Grid.Column="2"
                            Content="🗑️ Elimina Selezionati"
                            Style="{StaticResource DangerButton}"
                            Margin="0,0,10,0"
                            IsEnabled="{Binding HasSelectedItems}"
                            Click="DeleteButton_Click"/>

                    <Button x:Name="UploadToYouTubeButton"
                            Grid.Column="3"
                            Content="⬆️ Carica su YouTube"
                            IsEnabled="{Binding HasSelectedItems}"
                            Click="UploadToYouTubeButton_Click"/>
                </Grid>
            </Border>

            <!-- Progress Panel -->
            <Border x:Name="ProgressPanel"
                    Grid.Row="3"
                    Style="{StaticResource Card}"
                    Background="{StaticResource SurfaceBrush}"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="ProgressStatusText"
                               Text="Caricamento in corso..."
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock x:Name="CurrentFileText"
                               Text=""
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    
                    <ProgressBar x:Name="UploadProgressBar"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Background="{StaticResource BorderBrush}"
                                 Foreground="{StaticResource SuccessBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>