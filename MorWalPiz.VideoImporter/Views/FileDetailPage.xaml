<Window x:Class="MorWalPiz.VideoImporter.Views.FileDetailPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorWalPiz.VideoImporter.Views"
        mc:Ignorable="d"
        Title="Dettaglio File"
        Height="650"
        Width="800"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Original File Name -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📄 Nome file originale"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="OriginalFileNameTextBox"
                             IsReadOnly="True"
                             Background="{StaticResource BackgroundBrush}"/>
                </StackPanel>
            </Border>

            <!-- Clean File Name -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="✏️ Nome file pulito"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="CleanFileNameTextBox"
                             TextChanged="CleanFileNameTextBox_TextChanged"/>
                </StackPanel>
            </Border>

            <!-- Title -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📌 Titolo"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="TitleTextBox"/>
                </StackPanel>
            </Border>

            <!-- Description and Weapon CheckBox -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📝 Descrizione"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="DescriptionTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="80"
                             VerticalScrollBarVisibility="Auto"/>
                    <CheckBox x:Name="ContainsWeaponCheckBox"
                              Content="⚔️ Contiene Armi?"
                              Margin="0,12,0,0"
                              FontWeight="Medium"/>
                </StackPanel>
            </Border>

            <!-- Publish Date and Time -->
            <GroupBox Grid.Row="4" Header="📅 Data e ora di pubblicazione" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Data"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                        <DatePicker x:Name="PublishDatePicker"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Ora (HH:MM)"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="HourTextBox"
                                     Width="60"
                                     Margin="0,0,8,0"
                                     PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                            <TextBlock Text=":" 
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="MinuteTextBox"
                                     Width="60"
                                     PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Translations -->
            <GroupBox Grid.Row="5"
                      Header="🌍 Traduzioni"
                      Margin="0,0,0,15"
                      x:Name="TranslationsGroupBox">
                <ItemsControl x:Name="SecondaryLanguagesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Language Header -->
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Name}"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,0,0,15"/>

                                    <!-- Title Translation -->
                                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                        <TextBlock Text="Titolo"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   Margin="0,0,0,5"/>
                                        <TextBox x:Name="TitleTranslationTextBox"
                                                 Tag="{Binding Id}"
                                                 ToolTip="Titolo tradotto"/>
                                    </StackPanel>

                                    <!-- Description Translation -->
                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="Descrizione"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   Margin="0,0,0,5"/>
                                        <TextBox x:Name="DescriptionTranslationTextBox"
                                                 Tag="{Binding Id}"
                                                 Height="70"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 ToolTip="Descrizione tradotta"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <!-- Action Buttons -->
            <Border Grid.Row="7" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ResetButton"
                            Grid.Column="0"
                            Content="↺ Reset Nome"
                            Style="{StaticResource SecondaryButton}"
                            Width="120"
                            Click="ResetButton_Click"/>

                    <StackPanel Grid.Column="2" Style="{StaticResource DialogFooter}" Margin="0">
                        <Button x:Name="CancelButton"
                                Content="Annulla"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Margin="0,0,10,0"
                                Click="CancelButton_Click"/>
                        <Button x:Name="SaveButton"
                                Content="Salva"
                                Width="100"
                                Click="SaveButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>