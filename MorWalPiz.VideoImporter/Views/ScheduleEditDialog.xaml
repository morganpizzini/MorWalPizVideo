<Window x:Class="MorWalPiz.VideoImporter.Views.ScheduleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorWalPiz.VideoImporter.Views"
        mc:Ignorable="d"
        Title="Modifica Pianificazione"
        Height="500"
        Width="550"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="📝 Nome pianificazione"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="NameTextBox"/>
            </StackPanel>
        </Border>

        <!-- Time -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="⏰ Orario di pubblicazione (HH:MM)"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="HourTextBox" 
                             Width="60"
                             Margin="0,0,8,0" 
                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                             MaxLength="2"/>
                    <TextBlock Text=":" 
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,8,0"/>
                    <TextBox x:Name="MinuteTextBox" 
                             Width="60"
                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                             MaxLength="2"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Days of week -->
        <GroupBox Grid.Row="2" Header="📅 Giorni della settimana" Margin="0,0,0,15">
            <StackPanel>
                <CheckBox x:Name="MondayCheckBox" 
                          Content="Lunedì" 
                          Margin="0,5"
                          FontWeight="Medium"/>
                <CheckBox x:Name="TuesdayCheckBox" 
                          Content="Martedì" 
                          Margin="0,5"
                          FontWeight="Medium"/>
                <CheckBox x:Name="WednesdayCheckBox" 
                          Content="Mercoledì" 
                          Margin="0,5"
                          FontWeight="Medium"/>
                <CheckBox x:Name="ThursdayCheckBox" 
                          Content="Giovedì" 
                          Margin="0,5"
                          FontWeight="Medium"/>
                <CheckBox x:Name="FridayCheckBox" 
                          Content="Venerdì" 
                          Margin="0,5"
                          FontWeight="Medium"/>
                <CheckBox x:Name="SaturdayCheckBox" 
                          Content="Sabato" 
                          Margin="0,5"
                          FontWeight="Medium"/>
                <CheckBox x:Name="SundayCheckBox" 
                          Content="Domenica" 
                          Margin="0,5"
                          FontWeight="Medium"/>
            </StackPanel>
        </GroupBox>

        <!-- Buttons -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <StackPanel Style="{StaticResource DialogFooter}" Margin="0">
                <Button x:Name="CancelButton" 
                        Content="Annulla"
                        Style="{StaticResource SecondaryButton}"
                        Width="100" 
                        Margin="0,0,10,0" 
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" 
                        Content="Salva" 
                        Width="100" 
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>