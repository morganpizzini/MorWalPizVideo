<Page x:Class="MorWalPiz.VideoImporter.Views.TenantManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Gestione Tenant"
      Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Header -->
            <TextBlock Text="🏢 Gestione Tenant" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"/>

            <!-- New Tenant Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="➕ Nuovo Tenant"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="Nome:" 
                                   VerticalAlignment="Center" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,0"/>
                        
                        <TextBox x:Name="NewTenantNameTextBox" 
                                 Grid.Column="1" 
                                 VerticalAlignment="Center"
                                 MaxLength="100"
                                 KeyDown="NewTenantNameTextBox_KeyDown"/>
                        
                        <Button x:Name="AddTenantButton" 
                                Grid.Column="2" 
                                Content="Aggiungi" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="10,0,0,0"
                                Click="AddTenantButton_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Existing Tenants Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📋 Tenant Esistenti"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>
                    
                    <DataGrid x:Name="TenantsDataGrid" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="White"
                              BorderThickness="1"
                              BorderBrush="{StaticResource BorderBrush}"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FAFB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome" 
                                                Binding="{Binding Name}" 
                                                Width="*" 
                                                IsReadOnly="True"/>
                            
                            <DataGridTextColumn Header="Data Creazione" 
                                                Binding="{Binding CreatedDate, StringFormat='{}{0:dd/MM/yyyy}'}" 
                                                Width="120" 
                                                IsReadOnly="True"/>
                            
                            <DataGridCheckBoxColumn Header="Attivo" 
                                                    Binding="{Binding IsActive}" 
                                                    Width="80"/>
                            
                            <DataGridTemplateColumn Header="Azioni" 
                                                    Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="✏️" 
                                                    ToolTip="Modifica"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="8,4"
                                                    Margin="0,0,5,0"
                                                    Click="EditTenantButton_Click"
                                                    Tag="{Binding}"/>
                                            <Button Content="🗑️" 
                                                    ToolTip="Elimina"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Padding="8,4"
                                                    Click="DeleteTenantButton_Click"
                                                    Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Style="{StaticResource DialogFooterStyle}">
                <Button x:Name="RefreshButton" 
                        Content="🔄 Aggiorna" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="110"
                        Click="RefreshButton_Click"/>
                <Button x:Name="CloseButton" 
                        Content="Chiudi" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="100"
                        Margin="10,0,0,0"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>