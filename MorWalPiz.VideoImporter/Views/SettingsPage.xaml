<Window x:Class="MorWalPiz.VideoImporter.Views.SettingsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorWalPiz.VideoImporter.Views"
        mc:Ignorable="d"
        Title="Impostazioni"
        Height="550"
        Width="550"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Hashtags Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚙️ Hashtag Predefiniti"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Inserisci gli hashtag separati da virgola (esempio: video, social)"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"/>
                    
                    <TextBox x:Name="HashtagsTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Height="120"/>
                </StackPanel>
            </Border>

            <!-- API Configuration Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🔗 Configurazione API"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>
                    
                    <!-- API Endpoint -->
                    <TextBlock Text="API Endpoint"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="ApiEndpointTextBox"
                             Margin="0,0,0,15"/>
                    <!-- API Key -->
                    <TextBlock Text="API Key"
            FontWeight="SemiBold"
            Margin="0,0,0,5"/>
                    <TextBox x:Name="ApiKeyTextBox"
          Margin="0,0,0,15"/>

                    <!-- Application Name -->
                    <TextBlock Text="Application Name"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="ApplicationNameTextBox"/>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Style="{StaticResource DialogFooterStyle}">
                <Button x:Name="SaveButton"
                        Content="💾 Salva"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Click="SaveButton_Click"/>
                <Button x:Name="CancelButton"
                        Content="Annulla"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="100"
                        Margin="10,0,0,0"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>