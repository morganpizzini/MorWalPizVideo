<Window x:Class="MorWalPiz.VideoImporter.Views.LanguagesPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorWalPiz.VideoImporter.Views"
        xmlns:converters="clr-namespace:MorWalPiz.VideoImporter.Converters"
        mc:Ignorable="d"
        Title="Gestione Lingue"
        Height="600"
        Width="750"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
        <converters:NullToBooleanConverter x:Key="NullToBooleanConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Default Language Card -->
        <GroupBox Grid.Row="0" Header="🌐 Lingua Predefinita" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Seleziona lingua predefinita:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,15,0"/>
                <ComboBox x:Name="DefaultLanguageComboBox"
                          Grid.Column="1"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="DefaultLanguageComboBox_SelectionChanged"/>
            </Grid>
        </GroupBox>

        <!-- Languages Management -->
        <GroupBox Grid.Row="1" Header="🔤 Gestione Lingue" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Gestisci le lingue disponibili. Puoi aggiungere, modificare o eliminare lingue."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"/>

                <ListView x:Name="LanguagesListView"
                          Grid.Row="1"
                          Margin="0,0,0,15"
                          SelectionMode="Single"
                          BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  Click="SecondaryLanguage_Click"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Codice" 
                                            DisplayMemberBinding="{Binding Code}"
                                            Width="120"/>
                            <GridViewColumn Header="Nome"
                                            DisplayMemberBinding="{Binding Name}"
                                            Width="300"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal">
                    <Button x:Name="AddLanguageButton"
                            Content="➕ Aggiungi"
                            Style="{StaticResource PrimaryButton}"
                            Width="110"
                            Margin="0,0,10,0"
                            Click="AddLanguageButton_Click"/>
                    <Button x:Name="EditLanguageButton"
                            Content="✏️ Modifica"
                            Style="{StaticResource SecondaryButton}"
                            Width="110"
                            Margin="0,0,10,0"
                            Click="EditLanguageButton_Click"
                            IsEnabled="{Binding ElementName=LanguagesListView, Path=SelectedItem, Converter={StaticResource NullToBooleanConverter}}"/>
                    <Button x:Name="DeleteLanguageButton"
                            Content="🗑️ Elimina"
                            Style="{StaticResource DangerButton}"
                            Width="110"
                            Click="DeleteLanguageButton_Click"
                            IsEnabled="{Binding ElementName=LanguagesListView, Path=SelectedItem, Converter={StaticResource NullToBooleanConverter}}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel Style="{StaticResource DialogFooter}" Margin="0">
                <Button x:Name="CancelButton"
                        Content="Annulla"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton"
                        Content="Salva"
                        Width="100"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>