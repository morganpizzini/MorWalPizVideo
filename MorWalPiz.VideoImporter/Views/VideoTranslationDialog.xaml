<Window x:Class="MorWalPiz.VideoImporter.Views.VideoTranslationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorWalPiz.VideoImporter.Views"
        mc:Ignorable="d"
        Title="Traduci Video YouTube"
        Height="650"
        Width="850"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Control -->
        <TabControl x:Name="MainTabControl" 
                    Grid.Row="0" 
                    Margin="0,0,0,20"
                    Background="Transparent">
            <!-- Input Tab -->
            <TabItem Header="📝 Inserimento">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <!-- Title Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="📌 Titolo del Video"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                
                                <TextBlock Text="Inserisci il titolo del video da tradurre"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,10"
                                           TextWrapping="Wrap"/>
                                
                                <TextBox x:Name="TitleTextBox"
                                         Padding="8"/>
                            </StackPanel>
                        </Border>

                        <!-- Description Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="📄 Descrizione del Video"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                
                                <TextBlock Text="Inserisci la descrizione completa del video"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,10"
                                           TextWrapping="Wrap"/>
                                
                                <TextBox x:Name="DescriptionTextBox"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Height="200"
                                         Padding="8"
                                         FontFamily="Consolas"
                                         FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Translate Button -->
                        <Button x:Name="TranslateButton"
                                Content="🌐 Traduci"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Center"
                                Padding="30,10"
                                Click="TranslateButton_Click"
                                IsDefault="True"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Action Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Loading Indicator -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="⏳ Traduzione in corso..."
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>
                <ProgressBar IsIndeterminate="True"
                             Width="150"
                             Height="4"
                             VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Close Button -->
            <Button Grid.Column="1"
                    Content="Chiudi"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="20,8"
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>