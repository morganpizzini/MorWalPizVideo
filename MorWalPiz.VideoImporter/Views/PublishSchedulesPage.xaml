<Window x:Class="MorWalPiz.VideoImporter.Views.PublishSchedulesPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorWalPiz.VideoImporter.Views"
        mc:Ignorable="d"
        Title="Pianificazioni di Pubblicazione"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Add Button -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="📅 Gestisci le pianificazioni di pubblicazione per i tuoi video"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                
                <Button Grid.Column="1"
                        x:Name="AddScheduleButton"
                        Content="➕ Aggiungi Pianificazione"
                        Click="AddScheduleButton_Click"/>
            </Grid>
        </Border>

        <!-- Schedules List -->
        <GroupBox Grid.Row="1" Header="📋 Pianificazioni Attive" Margin="0,0,0,20">
            <ListView x:Name="SchedulesListView" BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Nome" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Giorni" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DaysDisplay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="⏰ Orario" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PublishTimeDisplay}"
                                               FontWeight="Medium"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Attivo" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay}" 
                                              HorizontalAlignment="Center"
                                              Checked="ActiveCheckBox_Changed"
                                              Unchecked="ActiveCheckBox_Changed"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Azioni" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏️ Modifica" 
                                                Style="{StaticResource SecondaryButton}"
                                                Width="70"
                                                Padding="8,4"
                                                Margin="0,0,8,0"
                                                Click="EditScheduleButton_Click"/>
                                        <Button Content="🗑️ Elimina" 
                                                Style="{StaticResource DangerButton}"
                                                Width="70"
                                                Padding="8,4"
                                                Click="DeleteScheduleButton_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Bottom Buttons -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel Style="{StaticResource DialogFooter}" Margin="0">
                <Button x:Name="RefreshButton"
                        Content="🔄 Aggiorna"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="RefreshButton_Click"/>
                <Button x:Name="CloseButton"
                        Content="Chiudi"
                        Width="100"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>