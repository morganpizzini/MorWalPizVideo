<Window x:Class="MorWalPiz.VideoImporter.Views.DisclaimerPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorWalPiz.VideoImporter.Views"
        mc:Ignorable="d"
        Title="Gestione Disclaimer"
        Height="550"
        Width="750"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Language Selector Card -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🌐 Seleziona lingua:" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,15,0"/>
                <ComboBox x:Name="LanguageSelector"
                          Width="220"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="LanguageSelector_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- Disclaimer Editor -->
        <GroupBox Grid.Row="1" Header="📝 Testo del disclaimer" Margin="0,0,0,20">
            <TextBox x:Name="DisclaimerTextBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="12"/>
        </GroupBox>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel Style="{StaticResource DialogFooter}">
                <Button x:Name="CancelButton"
                        Content="Annulla"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton"
                        Content="Salva"
                        Width="100"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>